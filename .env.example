# Firebase web app config — copy to `.env.local` and fill from the Firebase
# console (Project settings → General → Your apps → SDK setup and configuration).
# All are safe to expose in a client bundle; access is controlled by Firestore
# and Storage security rules, not by hiding these values.
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Set to "1" to point the app at local Firebase emulators (see `npm run emulators`).
VITE_USE_EMULATORS=
