rules_version = '2';

// tm-tracker Firestore security rules.
//
// Model (DESIGN.md §3/§12):
//  - The whole app is login-gated: every read requires auth.
//  - Anyone signed in may read user PROFILES (needed to render the leaderboard
//    and admin table). Profiles hold no secrets beyond email; scores/notes live
//    in the private `completions` subcollection.
//  - A user may edit their OWN profile's display fields, but NOT escalate
//    privileges: role + isTMStudent are admin-only, and paperCount may only
//    move by ±1 per write (honor-system logging; admins audit via completions).
//  - classId locks once onboarded (only admins reassign).
//  - Scores/notes (completions) are readable only by the owner + admins.
//  - Classes are admin-managed.

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function isAdmin() {
      return isSignedIn()
        && exists(/databases/$(database)/documents/users/$(request.auth.uid))
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    // The seed admin — recognised by verified Google email (keep in sync with
    // src/lib/config.ts BOOTSTRAP_ADMIN_EMAIL).
    function isBootstrapAdmin() {
      return isSignedIn() && request.auth.token.email == 'calvintkusnadi@gmail.com';
    }

    match /users/{uid} {
      allow read: if isSignedIn();

      // First sign-in: a user creates only their own doc, cannot self-grant
      // TM/admin (admin allowed only for the bootstrap email).
      allow create: if isOwner(uid)
        && request.resource.data.isTMStudent == false
        && request.resource.data.paperCount == 0
        && (request.resource.data.role == 'student'
            || (request.resource.data.role == 'admin' && isBootstrapAdmin()));

      // Admins can change anything. Owners can edit display fields only:
      //  - role / isTMStudent / email / createdAt are frozen,
      //  - paperCount may change by at most ±1 (honor-system logging),
      //  - classId is frozen once onboarded.
      // PLUS a one-shot self-promotion to admin: allowed only when the owner
      // holds a valid adminClaims doc (proof they entered the secret token —
      // see /adminClaims below). Such a promotion must drop them to no class
      // and leave email/createdAt/paperCount untouched.
      allow update: if isAdmin()
        || (isOwner(uid)
            && request.resource.data.role == resource.data.role
            && request.resource.data.isTMStudent == resource.data.isTMStudent
            && request.resource.data.email == resource.data.email
            && request.resource.data.createdAt == resource.data.createdAt
            && request.resource.data.paperCount >= resource.data.paperCount - 1
            && request.resource.data.paperCount <= resource.data.paperCount + 1
            && (request.resource.data.classId == resource.data.classId
                || resource.data.onboarded == false))
        || (isOwner(uid)
            && exists(/databases/$(database)/documents/adminClaims/$(uid))
            && request.resource.data.role == 'admin'
            && request.resource.data.isTMStudent == false
            && request.resource.data.classId == ''
            && request.resource.data.email == resource.data.email
            && request.resource.data.createdAt == resource.data.createdAt
            && request.resource.data.paperCount == resource.data.paperCount);

      allow delete: if isAdmin();

      // Private: scores + notes. Owner reads/writes; admins read (oversight).
      match /completions/{paperId} {
        allow read: if isOwner(uid) || isAdmin();
        allow create, update: if isOwner(uid)
          && (request.resource.data.score == null
              || (request.resource.data.score is number
                  && request.resource.data.score >= 0
                  && request.resource.data.score <= 100));
        allow delete: if isOwner(uid);
      }

      match /todos/{paperId} {
        allow read: if isOwner(uid) || isAdmin();
        allow write: if isOwner(uid);
      }
    }

    match /classes/{classId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isBootstrapAdmin();
    }

    // Bounties: admin-created prize competitions. Everyone signed in can read
    // them (they show on Home); only admins create/edit/delete.
    match /bounties/{bountyId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isBootstrapAdmin();
    }

    // Public, non-sensitive mirror of completions — timestamp + completed flag
    // only, NEVER score/notes (those stay in the private completions
    // subcollection). This lets any signed-in student see live bounty standings
    // (paper counts within a date range) without exposing private data. A user
    // may only write their own events (doc id is `{uid}__{paperId}`); admins may
    // delete (e.g. when removing a sign-up).
    match /completionEvents/{eventId} {
      allow read: if isSignedIn();
      allow create, update: if isSignedIn()
        && request.resource.data.uid == request.auth.uid;
      allow delete: if (isSignedIn() && resource.data.uid == request.auth.uid)
        || isAdmin();
    }

    // The shared admin-signup secret, validated ONLY inside these rules — never
    // readable or writable by any client (rule-side get() still sees it). Seed
    // `config/adminSecret = { token: "<secret>" }` out-of-band: Firebase console
    // or an admin-SDK script. Keep in sync with the token you hand to admins.
    match /config/{doc} {
      allow read, write: if false;
    }

    // One-shot admin claim. Creating `adminClaims/{uid}` requires the caller to
    // present the secret token (matched server-side against config/adminSecret);
    // its existence is what authorises self-promotion to admin in the users
    // rule above. Never client-readable — the token only lives here transiently
    // and the client deletes it right after promoting.
    match /adminClaims/{uid} {
      allow read: if false;
      allow create: if isOwner(uid)
        && request.resource.data.token ==
           get(/databases/$(database)/documents/config/adminSecret).data.token;
      allow delete: if isOwner(uid) || isAdmin();
    }

    // Default deny.
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
